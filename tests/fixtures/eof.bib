author = {Dong, Huixin and Lin, Jingqi and Cui, Minhao and Zhang, Serene and Qiu, Lili and Xiong, Jie and Wang, Wei},
title = {GPSoil: Towards low-cost soil moisture sensing using GNSS signals},
